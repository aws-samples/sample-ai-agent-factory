{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllOutsideSupportedRegions",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "cloudfront:*",
        "route53:*",
        "support:*",
        "trustedadvisor:*",
        "health:*",
        "budgets:*",
        "ce:*",
        "organizations:Describe*",
        "organizations:List*",
        "s3:ListAllMyBuckets",
        "s3:GetBucketLocation"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "us-west-2",
            "us-east-1",
            "eu-west-1"
          ]
        }
      }
    },
    {
      "Sid": "DenyLeavingTheOrganization",
      "Effect": "Deny",
      "Action": [
        "organizations:LeaveOrganization",
        "account:CloseAccount"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyBillingAndAccountMutation",
      "Effect": "Deny",
      "Action": [
        "aws-portal:Modify*",
        "billing:Update*",
        "account:PutAlternateContact",
        "account:DeleteAlternateContact"
      ],
      "Resource": "*"
    }
  ]
}
