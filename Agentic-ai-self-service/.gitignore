tasks/e2e-run/evidence/
tasks/e2e-run/state.json
tasks/e2e-run/platform.json
tasks/*-hero-dom-*.html

# Holmes local scan metadata
.holmes/
# Local-only e2e test-harness scratch (not product code; get_token.py holds a test password)
tasks/e2e-run/CORRECTED_SCOPE.md
tasks/e2e-run/scripts/get_token.py
tasks/e2e-run/scripts/m1probe.py
tasks/e2e-run/scripts/control_plane_run.py
